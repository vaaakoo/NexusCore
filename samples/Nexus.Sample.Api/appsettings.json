{
  "AllowedHosts": "*",

  // ── Serilog ──────────────────────────────────────────────────────────────────
  // Override the host-level minimum from LoggingExtensions here if needed.
  // Serilog will merge this with any values set via code.
  "Serilog": {
    "MinimumLevel": "Information"
  },

  // ── JWT Bearer ───────────────────────────────────────────────────────────────
  // IMPORTANT: In production, replace SecretKey with a secrets-manager reference
  // (Azure Key Vault, AWS Secrets Manager, HashiCorp Vault, or .NET User Secrets).
  // Never commit real credentials to source control.
  "Jwt": {
    "SecretKey":       "NexusCoreFramework_SuperSecret_SigningKey_32+Chars!",
    "Issuer":          "nexus.core.api",
    "Audience":        "nexus.clients",
    "ExpiryMinutes":   60,
    "ClockSkewSeconds": 30
  }
}
